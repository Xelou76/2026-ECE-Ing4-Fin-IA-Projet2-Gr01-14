# ============================================================
# market_regime — Configuration de l'environnement (.env)
# Copiez ce fichier en .env et ajustez les valeurs.
# ============================================================

# Seed global (reproductibilité totale)
RANDOM_SEED=42

# Niveau de logs : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---- Données ----
# Tickers yfinance séparés par des virgules
DATA__TICKERS=["SPY","TLT","GLD","VIX"]
DATA__BENCHMARK_TICKER=SPY
DATA__START_DATE=2005-01-01
DATA__END_DATE=2024-12-31
DATA__TRAIN_RATIO=0.7
DATA__VAL_RATIO=0.15

# ---- VAE ----
VAE__HIDDEN_DIM=128
VAE__LATENT_DIM=8
VAE__EPOCHS=150
VAE__BATCH_SIZE=64
VAE__LEARNING_RATE=0.001
VAE__EARLY_STOPPING_PATIENCE=20

# ---- HMM ----
HMM__N_REGIMES=3
HMM__COVARIANCE_TYPE=full
HMM__N_ITER=200
HMM__N_INIT=10
